{
  "name": "obsidian-halo-plus",
  "version": "0.1.0",
  "private": true,
  "description": "Publish Obsidian notes to Halo blog with native rendering support",
  "scripts": {
    "build": "pnpm -r run build",
    "build:sdk": "pnpm --filter @obsidian-halo-plus/halo-sdk run build",
    "build:plugin": "pnpm --filter obsidian-halo-plus run build",
    "build:cli": "pnpm --filter @obsidian-halo-plus/halo-cli run build",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "dev": "pnpm -r run dev",
    "clean": "pnpm -r run clean",
    "prepare": "husky",
    "release": "node scripts/release.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.5.3",
    "esbuild": "^0.19.0",
    "husky": "^9.1.7",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "license": "MIT"
}
