{
  "name": "@obsidian-halo-plus/halo-sdk",
  "version": "0.2.0",
  "description": "Halo REST API SDK for obsidian-halo-plus (wraps @halo-dev/api-client)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js --external:@halo-dev/api-client --external:axios && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.mjs --external:@halo-dev/api-client --external:axios",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js --external:@halo-dev/api-client --external:axios --watch",
    "lint": "biome check src/",
    "format": "biome format src/ --write"
  },
  "dependencies": {
    "@halo-dev/api-client": "^2.24.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT"
}
