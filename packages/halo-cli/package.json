{
  "name": "@obsidian-halo-plus/halo-cli",
  "version": "0.1.0",
  "description": "CLI tool for Halo API operations",
  "main": "dist/index.js",
  "bin": {
    "halo": "dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --watch",
    "lint": "biome check src/",
    "format": "biome format src/ --write"
  },
  "dependencies": {
    "@obsidian-halo-plus/halo-sdk": "workspace:*",
    "commander": "^11.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "esbuild": "^0.19.0"
  },
  "license": "MIT"
}
